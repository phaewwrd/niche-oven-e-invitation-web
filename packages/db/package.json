{
  "name": "@niche-e-invitation/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/seed.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@niche-e-invitation/env": "workspace:*",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@niche-e-invitation/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}