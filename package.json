{
  "name": "niche-e-invitation",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "better-auth": "^1.4.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @niche-e-invitation/db db:push",
    "db:studio": "turbo -F @niche-e-invitation/db db:studio",
    "db:generate": "turbo -F @niche-e-invitation/db db:generate",
    "db:migrate": "turbo -F @niche-e-invitation/db db:migrate",
    "db:seed": "turbo -F @niche-e-invitation/db db:seed"
  },
  "dependencies": {
    "@niche-e-invitation/env": "workspace:*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@niche-e-invitation/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.9"
}